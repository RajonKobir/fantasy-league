# Example environment variables for the Flutter app
# Copy this file to `.env` and fill values for your local/dev environment.

# Backend API base URL (no trailing slash)
API_BASE_URL=https://api.example.com
BRAINTREE_TOKENIZATION_KEY=REPLACE_ME

# CDN/Image URLs and legal/policy URLs
USER_IMAGE_URL=https://starsportsfantasy.com/Fantasy/image/user/
APP_ICON_URL=
LEGALITY_URL=https://starsportsfantasy.com/Fantasy/ligality

# Google Sign-In credentials for login (OAuth 2.0 client IDs from Google Cloud Console)
GOOGLE_CLIENT_ID_ANDROID=REPLACE_ME # e.g. com.googleusercontent.apps.xxxxxxxx-android
GOOGLE_CLIENT_ID_IOS=REPLACE_ME     # e.g. com.googleusercontent.apps.xxxxxxxx-ios

# Facebook login credentials (App ID from Facebook Developer Console)
FACEBOOK_APP_ID=REPLACE_ME          # e.g. 123456789012345
FACEBOOK_APP_NAME=FantasyLeagueApp  # Your Facebook app display name

# Other client-side config
FLAVOR=development

# Note: Do NOT store server secrets (API keys, DB passwords) in this client .env
